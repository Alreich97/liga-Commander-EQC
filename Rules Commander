<script>
  document.addEventListener("DOMContentLoaded", () => {
    
    // --- 1. LÓGICA DE LA CALCULADORA DE PUNTOS ---
    const calcInputs = document.querySelectorAll('.calc-container input');
    
    function calculateScore() {
      // Obtener posición (3, 2, 1, 0)
      const placementStr = document.querySelector('input[name="calc-place"]:checked')?.value || "0";
      const placement = parseInt(placementStr);
      const isWinner = (placement === 3);

      // Sumar logros
      let achPoints = 0;
      document.querySelectorAll('.calc-ach:checked').forEach(cb => achPoints += parseInt(cb.value));

      // Sumar penalizaciones
      let penPoints = 0;
      document.querySelectorAll('.calc-pen:checked').forEach(cb => penPoints += parseInt(cb.value));

      // Cálculo bruto
      let total = placement + achPoints - penPoints;
      
      // Aplicar límites
      const maxPts = isWinner ? 7 : 4;
      const limitMsg = document.getElementById('calc-limit-msg');

      if (total > maxPts) {
        total = maxPts;
        limitMsg.style.display = 'block';
        limitMsg.textContent = `¡Tope alcanzado! (Máximo ${maxPts} pts ${isWinner ? 'por ganar' : 'sin ganar'})`;
      } else {
        limitMsg.style.display = 'none';
      }

      // Actualizar UI
      document.getElementById('calc-total-score').textContent = total;
    }

    // Escuchar cambios en los inputs
    calcInputs.forEach(input => input.addEventListener('change', calculateScore));
    // Calcular estado inicial
    calculateScore();


    // --- 2. LÓGICA DE SCROLLSPY (RESALTADO DEL MENÚ) ---
    const sections = document.querySelectorAll('.section');
    const navLinks = document.querySelectorAll('nav a');

    window.addEventListener('scroll', () => {
      let currentSectionId = '';
      
      // Encontrar la sección actual basada en el scroll
      sections.forEach(section => {
        const sectionTop = section.offsetTop;
        const sectionHeight = section.clientHeight;
        if (pageYOffset >= (sectionTop - 150)) {
          currentSectionId = section.getAttribute('id');
        }
      });

      // Actualizar los enlaces de navegación
      navLinks.forEach(link => {
        link.classList.remove('active');
        if (link.getAttribute('href') === `#${currentSectionId}`) {
          link.classList.add('active');
          // Scrollear el menú horizontalmente si el item activo se oculta (para móviles)
          link.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
        }
      });
    });

  });
</script>

